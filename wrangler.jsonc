{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "personalwebsite",
	"compatibility_date": "2025-09-27",
	"observability": {
		"enabled": true
	},
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"compatibility_flags": [
		"nodejs_compat"
	]
}
